# ──────────────────────────────────────────────────────────────────────────────
# Estavo Brokers — Apache URL rewriting rules
# ──────────────────────────────────────────────────────────────────────────────

<IfModule mod_rewrite.c>
    RewriteEngine On

    # ── Referral links: /go/{slug} → /?ref={slug} ───────────────────────────
    # Direct 302 redirect — no PHP required.
    # Slug rules: starts + ends with alphanumeric, may contain hyphens, 2-30 chars.
    # Example: https://estavo-brokers.com/go/ahmed → https://estavo-brokers.com/?ref=ahmed
    # The referral.js script picks up ?ref= and rewrites all CTA links.
    RewriteRule ^go/([a-zA-Z0-9][a-zA-Z0-9-]{0,28}[a-zA-Z0-9])/?$  /?ref=$1  [R=302,L,NE]
</IfModule>

# ── Security headers ──────────────────────────────────────────────────────────
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>
